  <diagram id="bwf0a7Ij66V1909Hp1I2" name="Page-2">
    <mxGraphModel dx="1226" dy="1180" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle AFTER: Zero Trust Segmented Network Architecture\n\ncloud \&quot;Internet\&quot; {\n}\n\nnode \&quot;Identity Provider (IdP)\\nMFA(e.g. Microsoft AD) • Device Posture • Risk-Based Access\&quot; {\n}\n\nnode \&quot;ZTNA Gateway\\n(Application-Level Access)\&quot; {\n}\n\nrectangle \&quot;Billing Zone\\n(Microsegmented)\&quot; {\n  node \&quot;Billing App\&quot;\n  node \&quot;Billing Database\\n(mTLS + Policy)\&quot;\n}\n\nrectangle \&quot;Claims Zone\\n(Microsegmented)\&quot; {\n  node \&quot;Claims App\&quot;\n  node \&quot;Claims Database\\n(mTLS + Policy)\&quot;\n}\n\nrectangle \&quot;Clinical Systems Zone\\n(Microsegmented)\&quot; {\n  node \&quot;Clinical App\&quot;\n  node \&quot;Clinical Database\\n(mTLS + Policy)\&quot;\n}\n\nrectangle \&quot;Admin Services Zone\\n(Microsegmented)\&quot; {\n  node \&quot;Privileged Access Mgmt (PAM)\&quot;\n  node \&quot;Identity Services.\&quot;\n}\n\n\&quot;Internet\&quot; --&gt; \&quot;Identity Provider (IdP)\\nMFA • Device Posture • Risk-Based Access\&quot;\n\&quot;Identity Provider (IdP)\\nMFA • Device Posture • Risk-Based Access\&quot; --&gt; \&quot;ZTNA Gateway\\n(Application-Level Access)\&quot;\n\n\&quot;ZTNA Gateway\\n(Application-Level Access)\&quot; --&gt; \&quot;Billing App\&quot;\n\&quot;ZTNA Gateway\\n(Application-Level Access)\&quot; --&gt; \&quot;Claims App\&quot;\n\&quot;ZTNA Gateway\\n(Application-Level Access)\&quot; --&gt; \&quot;Clinical App\&quot;\n\&quot;ZTNA Gateway\\n(Application-Level Access)\&quot; --&gt; \&quot;Privileged Access Mgmt (PAM)\&quot;\n\n\&quot;Billing App\&quot; --&gt; \&quot;Billing Database\\n(mTLS + Policy)\&quot;\n\&quot;Claims App\&quot; --&gt; \&quot;Claims Database\\n(mTLS + Policy)\&quot;\n\&quot;Clinical App\&quot; --&gt; \&quot;Clinical Database\\n(mTLS + Policy)\&quot;\n\nnote right of \&quot;ZTNA Gateway\\n(Application-Level Access)\&quot;\nNo network-level access\nIdentity-based authorization\nContinuous verification\nend note\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="awElTtQfODV9QzyVPmaJ-1">
